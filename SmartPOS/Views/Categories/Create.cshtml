@model SmartPOS.Models.Category

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Category";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <!-- কার্ড মেকানিজম -->
        <div class="card-custom">
            <div class="mb-4">
                <h4 class="mb-1 text-dark fw-bold">Add New Category</h4>
                <small class="text-muted">Create a new product group for inventory organization</small>
            </div>

            <!-- ফর্ম শুরু -->
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken() <!-- সিকিউরিটি টোকেন -->

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                    <input asp-for="Name" class="form-control px-3 py-2" placeholder="e.g. Electronics, Food & Beverage" autofocus />
                    <!-- সার্ভার সাইড এরর মেসেজ দেখানোর জন্য নিচের লাইনটি গুরুত্বপূর্ণ -->
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-light px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Save Category
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- এই স্ক্রিপ্টগুলো ব্রাউজারেই ডাটা ভ্যালিডেশন চেক করে ফেলে, পেজ রিফ্রেশ হওয়া ছাড়াই -->
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}