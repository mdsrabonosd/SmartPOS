@model SmartPOS.Models.Category

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Category";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card-custom">
            <div class="mb-4">
                <h4 class="mb-1 text-dark fw-bold">Edit Category</h4>
                <small class="text-muted">Modify the details of an existing product category</small>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                    <input asp-for="Name" class="form-control px-3 py-2" placeholder="Category Name" autofocus />
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-light px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
                    </a>
                    <button type="submit" class="btn btn-warning px-4 text-dark fw-medium">
                        <i class="fa-solid fa-pen-to-square me-2"></i>Update Category
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}